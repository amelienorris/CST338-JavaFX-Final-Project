<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox alignment = "CENTER" spacing = "12"
  xmlns:fx="http://javafx.com/fxml"
  fx:controller = "controller.SignUpController">
  <Label text = "Create Account" style = "-fx-font-size: 24px; -fx-font-weight: bold;"/>
  <TextField fx:id="usernameField" promptText="Username" />
  <TextField fx:id="passwordField" promptText="Password" />
  <TextField fx:id="confirmPasswordField" promptText="Confirm Password" />
  <Label fx:id="error" style = "-fx-text-fill: red;" text = ""/>
  <Button text = "Sign Up" onAction="#Signup"/>
  <Button text = "Back to Login" onAction="#handleBacktoLogin"/>

</VBox>