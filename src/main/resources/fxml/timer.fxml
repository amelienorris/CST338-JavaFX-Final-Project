<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.WidgetController"
            prefHeight="400.0" prefWidth="600.0">

    <VBox spacing="10" alignment="CENTER"
          AnchorPane.topAnchor="100"
          AnchorPane.leftAnchor="100"
          AnchorPane.rightAnchor="100">

        <Label fx:id="timerLabel" text="25:00"/>

        <HBox spacing="10" alignment="CENTER">
            <Button text="Start" onAction="#startTimer"/>
            <Button text="Pause" onAction="#pauseTimer"/>
            <Button text="End" onAction="#endTimer"/>
        </HBox>

    </VBox>

</AnchorPane>