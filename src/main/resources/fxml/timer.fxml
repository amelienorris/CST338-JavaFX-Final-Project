<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.FocusController"
            prefHeight="400.0" prefWidth="600.0">

    <VBox spacing="15" alignment="CENTER"
          AnchorPane.topAnchor="100.0"
          AnchorPane.leftAnchor="100.0"
          AnchorPane.rightAnchor="100.0">

        <TextField fx:id="minutesField" promptText="Enter minutes"/>

        <Label fx:id="timerLabel" text="25:00"/>

        <HBox spacing="10" alignment="CENTER">
            <Button fx:id="startButton" text="Start" onAction="#startTimer"/>
            <Button fx:id="pauseButton" text="Pause" onAction="#pauseTimer"/>
            <Button fx:id="endButton" text="End" onAction="#endTimer"/>
        </HBox>

    </VBox>

</AnchorPane>